{
  "name": "sdv-front-new-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "next dev",
    "dev:backend": "convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "deploy:backend": "node ./scripts/sync-clerk-issuer.mjs && convex deploy --yes",
    "deploy:backend:dev": "node ./scripts/sync-clerk-issuer.mjs && convex dev --once",
    "convex:export:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/export-dev.ps1",
    "convex:export:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/export-prod.ps1",
    "convex:import:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/import-dev.ps1",
    "convex:import:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/import-prod.ps1",
    "doctor": "npx react-doctor@latest",
    "analyze": "cross-env ANALYZE=true next build"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.5.1",
    "@convex-dev/react-query": "^0.1.0",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.41.0",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.40.0",
    "input-otp": "^1.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-doctor": "^0.5.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.78.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "svix": "^1.95.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.9",
    "@tailwindcss/postcss": "^4",
    "cross-env": "^7.0.3",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "eslint": "^10.4.1",
    "eslint-config-next": "16.2.9",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4",
    "typescript": "^6.0.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
