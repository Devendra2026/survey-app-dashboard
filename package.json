{
  "packageManager": "bun@1.2.2",
  "name": "sdv-front-new-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "next dev",
    "dev:backend": "convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:convex": "eslint convex --config eslint.convex.config.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint:convex",
    "verify:clerk-keys": "node ./scripts/verify-clerk-keys.mjs",
    "verify:clerk-keys:prod": "node ./scripts/verify-clerk-keys.mjs --prod",
    "verify:clerk-production": "node ./scripts/verify-clerk-production.mjs",
    "smoke:production": "node ./scripts/smoke-production.mjs",
    "verify:google-maps-key": "node ./scripts/verify-google-maps-key.mjs",
    "test": "vitest run",
    "deploy:backend": "node ./scripts/sync-clerk-issuer.mjs && convex deploy --yes",
    "deploy:backend:dev": "node ./scripts/sync-clerk-issuer.mjs && convex dev --once",
    "deploy:backend:prod": "node ./scripts/sync-clerk-issuer.mjs --prod && convex deploy --yes",
    "sync:clerk:prod": "node ./scripts/sync-clerk-issuer.mjs --prod",
    "convex:export:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/export-dev.ps1",
    "convex:export:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/export-prod.ps1",
    "convex:import:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/import-dev.ps1",
    "convex:import:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/import-prod.ps1",
    "convex:deploy:selfhosted": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/deploy-selfhosted.ps1",
    "convex:import:selfhosted": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/import-selfhosted.ps1",
    "convex:import:ec2": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/import-via-ec2.ps1",
    "convex:verify:zip": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/verify-zip.ps1",
    "convex:prepare:import-zip": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/prepare-import-zip.ps1",
    "convex:post-import:selfhosted": "powershell -NoProfile -ExecutionPolicy Bypass -File convex-backups/post-import-checklist.ps1",
    "doctor": "npx react-doctor@latest",
    "analyze": "cross-env ANALYZE=true next build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@clerk/nextjs": "^7.5.7",
    "@convex-dev/react-query": "^0.1.0",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.41.0",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.40.0",
    "input-otp": "^1.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.1",
    "sonner": "^2.0.7",
    "svix": "^1.96.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@next/bundle-analyzer": "16.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-next": "16.2.9",
    "npm-run-all": "^4.1.5",
    "react-doctor": "^0.5.8",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
